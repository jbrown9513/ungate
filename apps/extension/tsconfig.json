{
	"extends": "@ungate/dev-kit/tsconfig-base",
	"compilerOptions": {
		"module": "commonjs",
		"lib": [
			"ES2022"
		],
		"moduleResolution": "node",
		"importHelpers": false,
		"noEmit": true
	},
	"include": [
		"src",
		"tests",
		"eslint.config.mjs",
		"tsup.config.ts",
		"vitest.config.ts"
	],
	"exclude": [
		"node_modules",
		"dist"
	]
}
